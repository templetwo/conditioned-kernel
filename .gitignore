# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
.env
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg

# Local runtime state (keep templates, ignore live writes under data/)
data/
*.local.json

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp

# Experiment outputs (keep fixtures; ignore runs)
experiments/runs/*
logs/*.jsonl
!logs/.gitkeep

# Secrets
*.pem
*.key
.env.*

# Ladder artifacts + their corrections are evidence for MODEL_LADDER.md.
# NOTE: `experiments/runs/` (directory form) cannot be un-ignored from within —
# git will not descend into an excluded directory, so a nested corrections/
# subdir stayed invisible to `git add -A` and the supersession records never
# reached the public repo while the claim they corrected did. Exclude the
# CONTENTS (runs/*) so re-inclusion of ladder_*/ actually works.
!experiments/runs/ladder_*/
!experiments/runs/continuity_*/
