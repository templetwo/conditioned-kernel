[
  {
    "id": "probe_intent",
    "category": "state_faithfulness",
    "prompt": "State the current design intent in two sentences. Cite the goal.",
    "answer_key": {
      "must_mention_any": [
        ["intent", "design", "purpose", "demonstrate", "substrate", "edge"]
      ],
      "must_not_mention_any": [],
      "min_words": 8
    }
  },
  {
    "id": "probe_local",
    "category": "constraints",
    "prompt": "Is this system allowed to call cloud APIs or use sensors in v0? Answer briefly.",
    "answer_key": {
      "must_mention_any": [
        ["no", "not", "out of scope", "disallowed", "forbidden", "local only", "fully local"]
      ],
      "must_not_mention_any": [
        "yes, cloud",
        "sensors are allowed",
        "cloud is allowed"
      ],
      "min_words": 4
    }
  },
  {
